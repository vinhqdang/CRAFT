\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Attack Success Rate (ASR) Comparison. Lower is better. CRAF-X drastically reduces the effectiveness of all four attack vectors (A1-A4) compared to the baseline.}}{9}{}\protected@file@percent }
