\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Robustness to Natural Sensor Degradation}{10}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces mAP Robustness under simulated LiDAR dropout. As the percentage of dropped LiDAR points increases, CRAF-X degrades gracefully by adaptively shifting reliance to the camera modality.}}{11}{}\protected@file@percent }
\newlabel{fig:degradation}{{8}{11}{}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Qualitative fallback during adverse weather. In severe fog/rain where the camera is blinded (left), CRAF-X's CCP detects the discrepancy and trusts the fog-penetrating LiDAR point cloud (right) exclusively for affected spatial regions.}}{11}{}\protected@file@percent }
\newlabel{fig:adverse_weather}{{9}{11}{}{figure.9}{}}
